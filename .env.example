# ============================================================
# mada_fisc_auto — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=changez-moi-par-une-cle-secure-de-50-caracteres-minimum
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Base de données PostgreSQL ---
POSTGRES_DB=mada_fisc
POSTGRES_USER=mada_user
POSTGRES_PASSWORD=mada_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Email (dev: console) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@mada-fisc.mg

# --- WeasyPrint ---
WEASYPRINT_MEDIA_ROOT=/app/media
